generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  createdGroups     Group[]           @relation("GroupCreator")
  groupMemberships  GroupMember[]
  paidExpenses      Expense[]         @relation("ExpensePaidBy")
  expenseShares     ExpenseParticipant[] @relation("ExpenseParticipant")
  settlementsFrom   Settlement[]      @relation("SettlementFrom")
  settlementsTo     Settlement[]      @relation("SettlementTo")
  importJobs        ImportJob[]
  aliases           UserAlias[]

  @@map("users")
}

model Group {
  id          String    @id @default(cuid())
  name        String
  description String?
  createdById String
  createdBy   User      @relation("GroupCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members      GroupMember[]
  expenses     Expense[]
  settlements  Settlement[]
  importJobs   ImportJob[]

  @@map("groups")
}

model GroupMember {
  id        String    @id @default(cuid())
  groupId   String
  userId    String
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?
  
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model Expense {
  id             String    @id @default(cuid())
  groupId        String
  paidById       String
  description    String
  totalAmount    Decimal   @db.Decimal(10, 2)
  splitType      String
  date           DateTime  @default(now())
  currency       String    @default("INR")
  originalAmount Decimal?  @db.Decimal(10, 2)
  exchangeRate   Decimal?  @db.Decimal(10, 6)
  type           String    @default("EXPENSE") // "EXPENSE" | "REFUND_TRANSACTION"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  group        Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy       User      @relation("ExpensePaidBy", fields: [paidById], references: [id])
  participants ExpenseParticipant[]

  @@map("expenses")
}

model ExpenseParticipant {
  id            String   @id @default(cuid())
  expenseId     String
  userId        String?
  guestName     String?
  guestEmail    String?
  amountOwed    Decimal  @db.Decimal(10, 2)
  splitMetadata Json?

  expense       Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user          User?    @relation("ExpenseParticipant", fields: [userId], references: [id])

  @@map("expense_participants")
}

model Settlement {
  id          String   @id @default(cuid())
  groupId     String
  fromUserId  String
  toUserId    String
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("INR")
  note        String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser    User     @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser      User     @relation("SettlementTo", fields: [toUserId], references: [id])

  @@map("settlements")
}

// User alias mapping for normalization
model UserAlias {
  id          String   @id @default(cuid())
  userId      String
  alias       String   // normalized alias
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, alias])
  @@map("user_aliases")
}

model ImportJob {
  id             String    @id @default(cuid())
  groupId        String
  userId         String
  fileName       String
  status         String    // PENDING, PROCESSING, COMPLETED, FAILED, REQUIRES_APPROVAL
  totalRows      Int
  processedRows  Int       @default(0)
  successfulRows Int       @default(0)
  failedRows     Int       @default(0)
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  rowData        Json?     // Stores the parsed/normalized rows list before final import

  group          Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id])
  anomalies      ImportAnomaly[]

  @@map("import_jobs")
}

model ImportAnomaly {
  id             String   @id @default(cuid())
  importJobId    String
  rowNumber      Int
  severity       String   // ERROR, WARNING, INFO
  anomalyType    String   // DUPLICATE, MISSING_FIELD, INVALID_DATE, etc.
  field          String?
  message        String
  originalValue  String?
  suggestedValue String?
  resolution     String?  // AUTO_FIXED, USER_APPROVED, SKIPPED
  rowData        Json
  createdAt      DateTime @default(now())

  importJob      ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@map("import_anomalies")
}
